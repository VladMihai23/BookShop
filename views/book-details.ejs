<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= book.title %> - Details</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<header>
    <%- include('navbar'); %>
</header>

<div class="container mt-5">

    <div class="row">

        <div class="col-md-4">
            <img src="<%= book.image_url %>" class="img-fluid rounded shadow" alt="<%= book.title %>">
        </div>

        <div class="col-md-8">
            <h1><%= book.title %></h1>
            <h4 class="text-muted"><%= book.author %></h4>
            <p><strong>Genre:</strong> <%= book.genre %></p>
            <p><strong>Price:</strong> $<%= book.price %></p>

            <p class="mt-4"><%= book.description ? book.description : "No description available." %></p>

            <% if (book.pdf_url) { %>
                <a href="<%= book.pdf_url %>" target="_blank" class="btn btn-outline-dark mt-3 me-2">View PDF</a>
            <% } %>

            <% if (session.user && session.user.role === 'user') { %>
                <form action="/cart/add/<%= book.id %>" method="POST">
                    <button class="btn btn-success">Add to Cart</button>
                </form>
            <% } %>

            <% if (session.user && session.user.role === 'admin') { %>
                <a href="/admin/books/edit/<%= book.id %>" class="btn btn-warning mt-3">Edit Book</a>
            <% } %>

        </div>

    </div>

    <% if (similarBooks && similarBooks.length > 0) { %>
        <div class="mt-5">
            <h4>Similar Books</h4>
            <div class="row">
                <% similarBooks.forEach(similarBook => { %>
                    <div class="col-md-4 mb-3">
                        <div class="card h-100 shadow-sm">
                            <img src="<%= similarBook.image_url %>" class="card-img-top" alt="<%= similarBook.title %>">
                            <div class="card-body text-center">
                                <h6><%= similarBook.title %></h6>
                                <p class="text-muted"><%= similarBook.author %></p>
                                <a href="/books/<%= similarBook.slug %>" class="btn btn-outline-primary btn-sm">
                                    View Book
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    <% } %>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
