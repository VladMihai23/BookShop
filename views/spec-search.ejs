<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Advanced Specification Search</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container py-5">
    <h2 class="mb-4">Advanced Search in Specification PDFs</h2>

    <form action="/spec-search/results" method="GET">
        <div class="mb-3">
            <input
                    type="text"
                    name="q"
                    class="form-control"
                    placeholder="Search inside PDF specifications..."
                    required
            >
        </div>

        <div class="mb-3">
            <select name="sort" class="form-select">
                <option value="desc">Score descending</option>
                <option value="asc">Score ascending</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Search</button>
    </form>
</div>
</body>
</html>