<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Specification Search Results</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container py-5">
    <h2 class="mb-4">Results for "<%= query %>"</h2>

    <form action="/spec-search/results" method="GET" class="row g-2 mb-4">
        <div class="col-md-8">
            <input type="text" name="q" class="form-control" value="<%= query %>" required>
        </div>
        <div class="col-md-2">
            <select name="sort" class="form-select">
                <option value="desc" <%= selectedSort === "desc" ? "selected" : "" %>>Score desc</option>
                <option value="asc" <%= selectedSort === "asc" ? "selected" : "" %>>Score asc</option>
            </select>
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary w-100">Search</button>
        </div>
    </form>

    <% if (!results.length) { %>
        <div class="alert alert-warning">No specification documents found.</div>
    <% } %>

    <div class="row">
        <% results.forEach(result => { %>
            <div class="col-md-6 mb-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title"><%= result.title %></h5>
                        <p><strong>Lucene/Solr score:</strong> <%= result.score %></p>

                        <% if (result.slug) { %>
                            <a href="/books/<%= result.slug %>" class="btn btn-outline-primary btn-sm">
                                Open Product
                            </a>
                        <% } %>

                        <% if (result.pdf_url) { %>
                            <a href="<%= result.pdf_url %>" target="_blank" class="btn btn-outline-dark btn-sm">
                                Open PDF
                            </a>
                        <% } %>

                        <div class="mt-3">
                            <small class="text-muted d-block mb-1">Score explanation</small>
                            <details>
                                <summary class="small">Show explain</summary>
                                <pre class="small bg-light p-2 mt-2 border rounded" style="white-space: pre-wrap;"><%= result.explain %></pre>
                            </details>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>
</body>
</html>